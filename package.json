{
  "name": "no-route-to-host",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "A browser-based network troubleshooting game where the player is the on-call network engineer",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "tsc -b && node packages/engine/dist/test/index.js",
    "validate": "tsc -b && node packages/validator/dist/index.js",
    "validate:hook": "node packages/hooks/dist/index.js",
    "watch:scenarios": "node packages/hooks/dist/index.js --watch",
    "mcp": "node packages/mcp-server/dist/index.js",
    "start": "node packages/server/dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0"
  }
}
